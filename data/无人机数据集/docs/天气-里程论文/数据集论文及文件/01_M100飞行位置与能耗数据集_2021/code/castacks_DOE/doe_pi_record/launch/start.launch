<launch>
<arg name="is_drone" default="1"/>

<node name="anemometer" pkg="anemometer" type="run.py" output="screen" if="$(arg is_drone)"/>
<node name="battery" pkg="battery" type="battery.py" output="screen"/>
<node name="environmental" pkg="environmental_sensor" type="sensor_node.py" output="screen" unless="$(arg is_drone)"/>
<include file="$(find microstrain_3dm_gx5_45)/launch/microstrain.launch" />
<node name="record" pkg="record" type="monitor.py" output="screen"/>
</launch>



}

sync_runtime() {
  local from_node=""
  local from_codex=""
  local codex_target_js codex_pkg_root platform_pkg_root target_triple target_name target_dir_name runtime_platform runtime_arch runtime_node_version source_label target_codex_pkg_root target_platform_pkg_root

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from-node)
        [[ $# -ge 2 ]] || die "--from-node 需要 node 路径"
        from_node="$2"
        shift 2
        ;;
      --from-node=*)
        from_node="${1#*=}"
        shift
        ;;
      --from-codex)
        [[ $# -ge 2 ]] || die "--from-codex 需要 codex 路径"
        from_codex="$2"
        shift 2
        ;;
      --from-codex=*)
        from_codex="${1#*=}"
        shift
        ;;
      *)
        die "sync-runtime 不支持参数: $1"
        ;;
    esac
  done

  [[ -n "${from_node}" ]] || die "请用 --from-node 指定 node 路径"
  [[ -n "${from_codex}" ]] || die "请用 --from-codex 指定 codex 路径"
  [[ -x "${from_node}" ]] || die "node 不可执行: ${from_node}"

  from_node="$(resolve_realpath "${from_node}")"
  from_codex="$(resolve_realpath "${from_codex}")"
  [[ -f "${from_codex}" ]] || die "codex 入口不存在: ${from_codex}"

  codex_target_js="$(python3 - "${from_codex}" <<'PY'
import pathlib
import sys

path = pathlib.Path(sys.argv[1]).resolve()
print(path)
PY
)"
  codex_pkg_root="$(cd "$(dirname "${codex_target_js}")/.." && pwd -P)"
  [[ -f "${codex_pkg_root}/package.json" ]] || die "无法识别 codex 包目录: ${codex_pkg_root}"

  runtime_platform="$("${from_node}" -p 'process.platform')"
  runtime_arch="$("${from_node}" -p 'process.arch')"
  runtime_node_version="$("${from_node}" -v)"
  source_label="${CODEX_PORTABLE_RUNTIME_SOURCE:-internal-refresh}"

  case "${runtime_platform}/${runtime_arch}" in
    linux/x64)
      target_triple="x86_64-unknown-linux-musl"
      target_name="@openai/codex-linux-x64"
      ;;
    linux/arm64)
      target_triple="aarch64-unknown-linux-musl"
      target_name="@openai/codex-linux-arm64"
      ;;
    darwin/x64)
      target_triple="x86_64-apple-darwin"
      target_name="@openai/codex-darwin-x64"
      ;;
    darwin/arm64)
      target_triple="aarch64-apple-darwin"
      target_name="@openai/codex-darwin-arm64"
      ;;
    win32/x64)
      target_triple="x86_64-pc-windows-msvc"
      target_name="@openai/codex-win32-x64"
      ;;
    win32/arm64)
      target_triple="aarch64-pc-windows-msvc"
      target_name="@openai/codex-win32-arm64"
      ;;
    *) die "未知 target triple: ${target_triple}" ;;
  esac

  target_dir_name="${target_name#@openai/}"
  platform_pkg_root="$("${from_node}" - "${codex_pkg_root}" "${target_name}" <<'NODE'
const path = require("path");
const { createRequire } = require("module");

const codexPkgRoot = process.argv[2];
const targetName = process.argv[3];
const requireFromCodex = createRequire(path.join(codexPkgRoot, "package.json"));

try {
  const pkgPath = requireFromCodex.resolve(`${targetName}/package.json`);
  process.stdout.write(path.dirname(pkgPath));
} catch {
  process.exit(1);
}
NODE
  )" || die "无法解析平台包: ${target_name}"

  target_codex_pkg_root="${RUNTIME_ROOT}/lib/node_modules/@openai/codex"
  target_platform_pkg_root="${target_codex_pkg_root}/node_modules/@openai/${target_dir_name}"

  mkdir -p "${RUNTIME_BIN_DIR}" "${RUNTIME_ROOT}/lib/node_modules/@openai"
  if [[ "${from_node}" != "${BUNDLED_NODE_BIN}" ]]; then
    cp "${from_node}" "${BUNDLED_NODE_BIN}"
    chmod +x "${BUNDLED_NODE_BIN}"
  fi

  if [[ "${codex_pkg_root}" != "${target_codex_pkg_root}" ]]; then
    rm -rf "${target_codex_pkg_root}"
    cp -R "${codex_pkg_root}" "${target_codex_pkg_root}"
  fi

  case "${platform_pkg_root}" in
    "${codex_pkg_root}"|"${codex_pkg_root}"/*)
      ;;
    *)
      mkdir -p "$(dirname "${target_platform_pkg_root}")"
      rm -rf "${target_platform_pkg_root}"
      cp -R "${platform_pkg_root}" "${target_platform_pkg_root}"
      ;;
  esac

  rm -f "${RUNTIME_BIN_DIR}/codex"
  cat > "${RUNTIME_BIN_DIR}/codex" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
RUNTIME_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
exec "${SCRIPT_DIR}/node" "${RUNTIME_ROOT}/lib/node_modules/@openai/codex/bin/codex.js" "$@"
EOF
  chmod +x "${RUNTIME_BIN_DIR}/codex"

  python3 - "${RUNTIME_ROOT}/portable-runtime.json" "${from_node}" "${codex_pkg_root}/package.json" "${target_triple}" "${target_name}" "${runtime_node_version}" "${source_label}" <<'PY'
import json
import pathlib
import sys
import time

meta_path = pathlib.Path(sys.argv[1])
node_path = sys.argv[2]
pkg_path = pathlib.Path(sys.argv[3])
target_triple = sys.argv[4]
target_name = sys.argv[5]
node_version = sys.argv[6]
source_label = sys.argv[7]
pkg = json.loads(pkg_path.read_text(encoding="utf-8"))
payload = {
    "updated_at": int(time.time()),
    "node_path_source": node_path,
    "node_version": node_version,
    "codex_version": pkg.get("version", ""),
    "target_triple": target_triple,
    "platform_package": target_name,
    "install_source": source_label,
}
meta_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY

  printf 'runtime synced\n'
  printf 'node=%s\n' "${BUNDLED_NODE_BIN}"
  printf 'codex=%s\n' "${BUNDLED_CODEX_BIN}"
  printf 'target=%s\n' "${target_triple}"
}

status() {
  local sessions_root="${LOCAL_CODEX_HOME}/sessions"

  resolve_selected_profile 0
  resolve_workspace_dir
  repair_state_paths quiet
  update_portable_metadata

  python3 - "${TOOLKIT_ROOT}" "${PROJECT_ROOT}" "${WORKSPACE_DIR}" "${CONFIGS_ROOT}" "${SELECTED_PROFILE}" "${SELECTED_PROFILE_DIR}" "${LOCAL_CODEX_HOME}" "${sessions_root}" "${CODEX_BIN}" "${PORTABLE_META_PATH}" "${DEFAULT_YOLO_ENABLED}" <<'PY'
import glob
import json
import os
import sys
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:
    try:
        import tomli as tomllib
    except ModuleNotFoundError:
        tomllib = None

toolkit_root, project_root, workspace_dir, configs_root, profile, profile_dir, local_home, sessions_root, codex_bin, meta_path, default_yolo = sys.argv[1:]
session_rows = []
meta = {}

meta_file = Path(meta_path)
if meta_file.exists():
    try:
        meta = json.loads(meta_file.read_text(encoding="utf-8"))
    except Exception:
        meta = {}

for path in sorted(glob.glob(os.path.join(sessions_root, "*", "*", "*", "*.jsonl")), reverse=True):
    try:
        with open(path, "r", encoding="utf-8") as fh:
            lines = fh.readlines()
    except Exception:
        continue
    if not lines:
        continue
    try:
        first = json.loads(lines[0])
    except Exception:
        continue
    if first.get("type") != "session_meta":
        continue
    payload = first.get("payload", {})
    latest_timestamp = str(first.get("timestamp", "")) or str(payload.get("timestamp", ""))
    for raw_line in lines[1:]:
        try:
            item = json.loads(raw_line)
        except Exception:
            continue
        current_timestamp = str(item.get("timestamp", ""))
        if current_timestamp > latest_timestamp:
            latest_timestamp = current_timestamp
    session_rows.append({
        "timestamp": latest_timestamp or str(payload.get("timestamp", "")),
        "session_id": payload.get("id", ""),
        "cwd": payload.get("cwd", ""),
    })

session_rows.sort(key=lambda row: (row["timestamp"], row["session_id"]), reverse=True)

profile_cfg_path = Path(profile_dir) / "config.toml"
runtime_cfg_path = Path(local_home) / "config.toml"

def read_base_url(path: Path) -> str:
    if not path.exists():
        return ""
    text = path.read_text(encoding="utf-8")
    if tomllib is not None:
        try:
            obj = tomllib.loads(text)
        except Exception:
            obj = None
        if obj is not None:
            provider = obj.get("model_provider", "")
            providers = obj.get("model_providers", {}) or {}
            provider_obj = providers.get(provider, {}) or {}
            return str(provider_obj.get("base_url", ""))

    provider = ""
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("model_provider"):
            parts = line.split("=", 1)
            if len(parts) == 2:
                provider = parts[1].strip().strip('"').strip("'")
            break

    if not provider:
        return ""

    current_section = ""
    target_section = "model_providers." + provider
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            current_section = line[1:-1].strip()
            continue
        if current_section == target_section and line.startswith("base_url"):
            parts = line.split("=", 1)
            if len(parts) == 2:
                return parts[1].strip().strip('"').strip("'")
    return ""

print(f"toolkit_root: {toolkit_root}")
print(f"project_root: {project_root}")
print(f"workspace_dir: {workspace_dir}")
print(f"configs_root: {configs_root}")
print(f"selected_profile: {profile}")
print(f"selected_profile_dir: {profile_dir}")
print(f"local_codex_home: {local_home}")
print(f"codex_bin: {codex_bin}")
print(f"session_count: {len(session_rows)}")
print(f"previous_toolkit_root: {meta.get('previous_toolkit_root', '')}")
print(f"previous_project_root: {meta.get('previous_project_root', '')}")
print(f"previous_workspace_dir: {meta.get('previous_workspace_dir', '')}")
print(f"relocation_detected: {'yes' if meta.get('previous_toolkit_root') and meta.get('previous_toolkit_root') != toolkit_root else 'no'}")
print(f"default_yolo: {'enabled' if default_yolo != '0' else 'disabled'}")
print(f"inherited_openai_api_key: {'yes' if os.environ.get('OPENAI_API_KEY') else 'no'}")
print(f"inherited_openai_base_url: {os.environ.get('OPENAI_BASE_URL', '')}")
print(f"inherited_openai_api_base: {os.environ.get('OPENAI_API_BASE', '')}")
print(f"selected_profile_base_url: {read_base_url(profile_cfg_path)}")
print(f"runtime_base_url: {read_base_url(runtime_cfg_path)}")

if session_rows:
    last = session_rows[0]
    print(f"last_session_id: {last['session_id']}")
    print(f"last_session_timestamp: {last['timestamp']}")
    print(f"last_session_cwd: {last['cwd']}")
else:
    print("last_session_id: ")
    print("last_session_timestamp: ")
    print("last_session_cwd: ")
PY
}

selftest() {
  ensure_requirements
  resolve_selected_profile 0
  resolve_workspace_dir
  repair_state_paths quiet
  update_portable_metadata

  python3 - "${TOOLKIT_ROOT}" "${PROJECT_ROOT}" "${WORKSPACE_DIR}" "${CONFIGS_ROOT}" "${SELECTED_PROFILE}" "${SELECTED_PROFILE_DIR}" "${LOCAL_CODEX_HOME}" "${CODEX_BIN}" "${DEFAULT_YOLO_ENABLED}" <<'PY'
import glob
import json
import sqlite3
import sys
from pathlib import Path

toolkit_root = Path(sys.argv[1])
project_root = Path(sys.argv[2])
workspace_dir = Path(sys.argv[3])
configs_root = Path(sys.argv[4])
profile = sys.argv[5]
profile_dir = Path(sys.argv[6])
local_home = Path(sys.argv[7])
codex_bin = sys.argv[8]
default_yolo = sys.argv[9]
db_path = local_home / "state_5.sqlite"
sessions_root = local_home / "sessions"

bad_rollouts = 0
session_files = 0
if sessions_root.exists():
    session_files = len(list(sessions_root.rglob("*.jsonl")))

if db_path.exists():
    con = sqlite3.connect(str(db_path))
    cur = con.cursor()
    rows = cur.execute("select rollout_path from threads").fetchall()
    for (rollout_path,) in rows:
        if rollout_path and not str(rollout_path).startswith(str(local_home)):
            bad_rollouts += 1
    con.close()

result = {
    "toolkit_exists": toolkit_root.is_dir(),
    "project_exists": project_root.is_dir(),
    "workspace_exists": workspace_dir.is_dir(),
    "configs_root_exists": configs_root.is_dir(),
    "profile_valid": profile_dir.is_dir() and (profile_dir / "auth.json").is_file() and (profile_dir / "config.toml").is_file(),
    "codex_bin": codex_bin,
    "local_codex_home_exists": local_home.is_dir(),
    "session_files": session_files,
    "bad_rollout_paths": bad_rollouts,
    "portable_ready": bad_rollouts == 0,
    "default_yolo": default_yolo != "0",
    "selected_profile": profile,
    "project_root": str(project_root),
    "workspace_dir": str(workspace_dir),
    "toolkit_root": str(toolkit_root),
}
print(json.dumps(result, ensure_ascii=False, indent=2))
PY
}

subcommand="${1:-start}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "${subcommand}" in
  runtime)
    exec "${SCRIPT_DIR}/codex-project-runtime" "$@"
    ;;
  init)
    exec "${SCRIPT_DIR}/codex-project-init" "$@"
    ;;
  pack)
    exec "${SCRIPT_DIR}/codex-project-pack" "$@"
    ;;
  help|-h|--help)
    usage
    exit 0
    ;;
esac

parse_common_flags "$@"
if [[ "${REMAINING_ARGS_COUNT}" -gt 0 ]]; then
  set -- "${REMAINING_ARGS[@]}"
else
  set --
fi

case "${subcommand}" in
  start)
    resolve_workspace_dir
    run_codex -C "${WORKSPACE_DIR}" "$@"
    ;;
  resume)
    [[ $# -ge 1 ]] || die "resume 需要 session id"
    session_id="$1"
    shift
    resolve_workspace_dir
    run_codex -C "${WORKSPACE_DIR}" resume --all "${session_id}" "$@"
    ;;
  last)
    resolve_workspace_dir
    run_codex -C "${WORKSPACE_DIR}" resume --all --last "$@"
    ;;
  pick)
    resolve_workspace_dir
    run_codex -C "${WORKSPACE_DIR}" resume --all "$@"
    ;;
  exec)
    run_codex_exec "$@"
    ;;
  exec-resume)
    [[ $# -ge 1 ]] || die "exec-resume 需要 session id"
    session_id="$1"
    shift
    run_codex_exec_resume "${session_id}" "$@"
    ;;
  sessions)
    if [[ "${1:-}" == "--json" ]]; then
      list_sessions json
    else
      list_sessions table
    fi
    ;;
  profiles)
    if [[ "${1:-}" == "--json" ]]; then
      list_profiles json
    else
      list_profiles table
    fi
    ;;
  where)
    show_where
    ;;
  doctor)
    doctor
    ;;
  status)
    status
    ;;
  repair-state)
    repair_state_paths normal
    ;;
  selftest)
    selftest
    ;;
  sync-runtime)
    sync_runtime "$@"
    ;;
  *)
    die "未知子命令: ${subcommand}。使用 'codex-project help' 查看帮助。"
    ;;
esac

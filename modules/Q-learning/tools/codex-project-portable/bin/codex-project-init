#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
TOOLKIT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
INIT_CONFIG_PATH="${TOOLKIT_ROOT}/portable-init.env"
INTERNAL_CONFIGS_ROOT="${TOOLKIT_ROOT}/mycodex/configs"
INTERNAL_SESSIONS_ROOT="${TOOLKIT_ROOT}/mycodex/sessions"
CONFIGS_ROOT=""
SESSIONS_ROOT=""
RUNTIME_ROOT="${TOOLKIT_ROOT}/runtime"
STATE_DIR="${TOOLKIT_ROOT}/state"
VALID_PROFILES_COUNT=0

PROJECT_NAME=""
PROJECT_ROOT=""
WORKSPACE_DIR=""
DEFAULT_PROFILE=""
STATE_ROOT=""
USE_INTERNAL_STATE="0"
IMPORT_EXISTING_STATE="0"
FORCE_WRITE="0"
RUNTIME_MODE=""

die() {
  printf '错误: %s\n' "$*" >&2
  exit 1
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

list_child_dirs() {
  python3 - "$1" <<'PY'
import os
import sys

root = sys.argv[1]
try:
    entries = sorted(entry.name for entry in os.scandir(root) if entry.is_dir())
except FileNotFoundError:
    entries = []

for name in entries:
    print(name)
PY
}

usage() {
  cat <<'EOF'
Codex Project Portable 初始化工具

用途：
  把当前工具目录初始化为“某个项目内的便携模块”。
  初始化后会在工具根目录生成 portable-init.env，
  用来持久保存：
    - 项目名称
    - 相对工具目录的 project_root
    - 相对工具目录的默认 workspace_dir
    - 默认 profile

常用示例：
  ./bin/codex-project-init
  ./bin/codex-project-init --force --skip-runtime
  ./bin/codex-project-init --project-root ../.. --workspace-dir ../.. --profile zys
  ./bin/codex-project-init --state-root ../.codex-portable --profile zys
  ./bin/codex-project init

可选参数：
  --project-name <name>
    指定项目名称；默认取 project_root 的目录名。

  --project-root <dir>
    指定项目根目录；默认优先推断为工具所在项目。

  --workspace-dir <dir>
    指定默认工作目录；默认等于 project_root。

  --profile <name>
    指定默认 profile；默认优先 zys，否则取第一个有效 profile。

  --state-root <dir>
    指定一个工具目录外的状态根目录。
    后续直接运行 ./bin/codex-project 时，会默认使用：
      <state-root>/configs
      <state-root>/sessions
    这也是当前默认模式；若目标目录为空，初始化时可按需把旧的
    工具内 mycodex/configs 和 mycodex/sessions 复制过去。

  --internal-state
    不使用工具目录外的状态根目录，继续沿用工具内 mycodex/。
    默认不会主动生成 mycodex/；只有显式使用本参数时才会创建。

  --import-existing-state
    把当前工具内已有的 mycodex/configs 和 mycodex/sessions
    复制到外部状态根目录。默认不复制，保持现有 mycodex 不动。

  --install-runtime
    初始化完成后，立即执行工具内 runtime install。

  --skip-runtime
    初始化完成后，不自动安装 runtime。

  --force
    若 portable-init.env 已存在，直接覆盖。

  -h, --help
    打印帮助。
EOF
}

default_project_root_guess() {
  local toolkit_parent

  toolkit_parent="$(cd "${TOOLKIT_ROOT}/.." && pwd -P)"
  if [[ "$(basename "${toolkit_parent}")" == "tools" ]]; then
    cd "${toolkit_parent}/.." && pwd -P
    return
  fi

  printf '%s\n' "${toolkit_parent}"
}

default_state_root_guess() {
  local toolkit_parent

  toolkit_parent="$(cd "${TOOLKIT_ROOT}/.." && pwd -P)"
  printf '%s/.codex-portable\n' "${toolkit_parent}"
}

set_active_state_roots() {
  if [[ "${USE_INTERNAL_STATE}" == "1" ]]; then
    CONFIGS_ROOT="${INTERNAL_CONFIGS_ROOT}"
    SESSIONS_ROOT="${INTERNAL_SESSIONS_ROOT}"
  else
    [[ -n "${STATE_ROOT}" ]] || STATE_ROOT="$(default_state_root_guess)"
    CONFIGS_ROOT="${STATE_ROOT}/configs"
    SESSIONS_ROOT="${STATE_ROOT}/sessions"
  fi
}

resolve_abs_dir() {
  local path="$1"
  local resolved=""
  [[ -n "${path}" ]] || die "目录路径不能为空"
  if ! resolved="$(python3 - "${path}" <<'PY'
import os
import sys

target = sys.argv[1]
if not os.path.isdir(target):
    raise SystemExit(1)

print(os.path.realpath(target))
PY
  )"; then
    die "目录不存在: ${path}"
  fi

  printf '%s\n' "${resolved}"
}

ensure_abs_dir() {
  local path="$1"
  [[ -n "${path}" ]] || die "目录路径不能为空"
  mkdir -p "${path}"
  cd "${path}" && pwd -P
}

relative_to_toolkit_root() {
  local abs_path="$1"
  python3 - "${TOOLKIT_ROOT}" "${abs_path}" <<'PY'
import os
import sys

toolkit_root = os.path.realpath(sys.argv[1])
target = os.path.realpath(sys.argv[2])
print(os.path.relpath(target, toolkit_root))
PY
}

path_has_entries() {
  python3 - "$1" <<'PY'
import os
import sys

target = sys.argv[1]
try:
    with os.scandir(target) as entries:
        for _entry in entries:
            print("yes")
            raise SystemExit(0)
except FileNotFoundError:
    pass

print("no")
PY
}

copy_tree_if_target_empty() {
  local source_dir="$1"
  local target_dir="$2"
  local label="$3"

  [[ -d "${source_dir}" ]] || return 0
  mkdir -p "${target_dir}"

  if [[ "$(path_has_entries "${source_dir}")" != "yes" ]]; then
    return 0
  fi

  if [[ "$(path_has_entries "${target_dir}")" == "yes" ]]; then
    printf '提示：目标 %s 目录非空，未自动覆盖：%s\n' "${label}" "${target_dir}"
    return 0
  fi

  cp -R "${source_dir}/." "${target_dir}/"
  printf '已复制 %s 到：%s\n' "${label}" "${target_dir}"
}

load_valid_profiles_into_array() {
  local __target_name="$1"
  local __profile_name
  local __count=0

  eval "${__target_name}=()"
  while IFS= read -r __profile_name; do
    eval "${__target_name}+=(\"\${__profile_name}\")"
    __count=$((__count + 1))
  done < <(valid_profiles)
  VALID_PROFILES_COUNT="${__count}"
}

ensure_keep_files() {
  mkdir -p "${RUNTIME_ROOT}" "${STATE_DIR}"
}

profile_is_valid() {
  local dir="${CONFIGS_ROOT}/$1"
  [[ -d "${dir}" && -f "${dir}/auth.json" && -f "${dir}/config.toml" ]]
}

valid_profiles() {
  local path

  [[ -d "${CONFIGS_ROOT}" ]] || return 0
  while IFS= read -r path; do
    if profile_is_valid "${path}"; then
      printf '%s\n' "${path}"
    fi
  done < <(list_child_dirs "${CONFIGS_ROOT}")
}

default_profile_name() {
  if profile_is_valid "zys"; then
    printf 'zys\n'
    return 0
  fi

  valid_profiles | head -n 1 || true
}

choose_profile_interactively() {
  local default_profile="$1"
  shift
  local -a profiles=("$@")
  local index answer

  printf '\n检测到以下有效 profile：\n' >&2
  index=1
  for answer in "${profiles[@]}"; do
    if [[ "${answer}" == "${default_profile}" ]]; then
      printf '  %d. %s（默认）\n' "${index}" "${answer}" >&2
    else
      printf '  %d. %s\n' "${index}" "${answer}" >&2
    fi
    index=$((index + 1))
  done

  while true; do
    printf '选择默认 profile [1-%d]，直接回车使用 %s：' "${#profiles[@]}" "${default_profile}" >&2
    read -r answer || exit 1

    if [[ -z "${answer}" ]]; then
      printf '%s\n' "${default_profile}"
      return 0
    fi

    if [[ "${answer}" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#profiles[@]} )); then
      printf '%s\n' "${profiles[$((answer - 1))]}"
      return 0
    fi

    printf '输入无效，请重新选择。\n' >&2
  done
}

prompt_with_default() {
  local label="$1"
  local default_value="$2"
  local answer

  printf '%s [%s]：' "${label}" "${default_value}" >&2
  read -r answer || exit 1
  printf '%s\n' "${answer:-${default_value}}"
}

prompt_existing_dir_with_default() {
  local label="$1"
  local default_value="$2"
  local raw_value answer resolved

  while true; do
    printf '%s [%s]：' "${label}" "${default_value}" >&2
    read -r answer || exit 1
    raw_value="${answer:-${default_value}}"

    if ! resolved="$(python3 - "${raw_value}" <<'PY'
import os
import sys

target = sys.argv[1]
if not os.path.isdir(target):
    raise SystemExit(1)

print(os.path.realpath(target))
PY
    )"; then
      printf '目录不存在，请重新输入：%s\n' "${raw_value}" >&2
      continue
    fi

    printf '已解析目录：%s\n' "${resolved}" >&2
    if prompt_yes_no "确认使用该目录" "y"; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  done
}

prompt_yes_no() {
  local label="$1"
  local default_answer="$2"
  local answer normalized

  while true; do
    printf '%s [%s]：' "${label}" "${default_answer}" >&2
    read -r answer || exit 1
    answer="${answer:-${default_answer}}"
    normalized="$(printf '%s' "${answer}" | tr '[:upper:]' '[:lower:]')"
    case "${normalized}" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) printf '请输入 y 或 n。\n' >&2 ;;
    esac
  done
}

write_init_config() {
  local project_root_relative="$1"
  local workspace_relative="$2"
  local state_root_relative="${3:-}"
  local internal_state_flag="${4:-0}"

  python3 - "${INIT_CONFIG_PATH}" "${PROJECT_NAME}" "${project_root_relative}" "${workspace_relative}" "${DEFAULT_PROFILE}" "${state_root_relative}" "${internal_state_flag}" <<'PY'
import pathlib
import sys

config_path = pathlib.Path(sys.argv[1])
project_name = sys.argv[2]
project_root_relative = sys.argv[3]
workspace_relative = sys.argv[4]
default_profile = sys.argv[5]
state_root_relative = sys.argv[6]
internal_state_flag = sys.argv[7]

def quote(value: str) -> str:
    return "'" + value.replace("'", "'\"'\"'") + "'"

lines = [
    "# 由 codex-project init 自动生成。",
    "# 建议把这份文件随项目一起提交和复制。",
    "# 如需临时覆盖，优先使用环境变量：",
    "#   CODEX_PORTABLE_PROJECT_ROOT",
    "#   CODEX_PORTABLE_WORKSPACE_DIR",
    "#   CODEX_PORTABLE_WORKSPACE_ROOT_NAME",
    "#   CODEX_PORTABLE_PROFILE",
    "#   CODEX_PORTABLE_STATE_ROOT",
    "#   CODEX_PORTABLE_HOME",
    "#   CODEX_PORTABLE_CONFIGS_ROOT",
    f"CODEX_PORTABLE_INIT_PROJECT_NAME={quote(project_name)}",
    f"CODEX_PORTABLE_INIT_PROJECT_ROOT_RELATIVE={quote(project_root_relative)}",
    f"CODEX_PORTABLE_INIT_WORKSPACE_DIR_RELATIVE={quote(workspace_relative)}",
]

if default_profile:
    lines.append(f"CODEX_PORTABLE_INIT_DEFAULT_PROFILE={quote(default_profile)}")

if state_root_relative:
    lines.append(f"CODEX_PORTABLE_INIT_STATE_ROOT_RELATIVE={quote(state_root_relative)}")

if internal_state_flag == "1":
    lines.append("CODEX_PORTABLE_INIT_INTERNAL_STATE='1'")

config_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
PY
}

runtime_ready() {
  [[ -x "${RUNTIME_ROOT}/bin/node" ]] \
    && [[ -x "${RUNTIME_ROOT}/bin/npm" ]] \
    && [[ -x "${RUNTIME_ROOT}/bin/codex" ]] \
    && [[ -f "${RUNTIME_ROOT}/lib/node_modules/@openai/codex/bin/codex.js" ]]
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-name)
        [[ $# -ge 2 ]] || die "--project-name 需要参数"
        PROJECT_NAME="$2"
        shift 2
        ;;
      --project-name=*)
        PROJECT_NAME="${1#*=}"
        shift
        ;;
      --project-root)
        [[ $# -ge 2 ]] || die "--project-root 需要参数"
        PROJECT_ROOT="$2"
        shift 2
        ;;
      --project-root=*)
        PROJECT_ROOT="${1#*=}"
        shift
        ;;
      --workspace-dir|--workspace|--cwd)
        [[ $# -ge 2 ]] || die "$1 需要参数"
        WORKSPACE_DIR="$2"
        shift 2
        ;;
      --workspace-dir=*|--workspace=*|--cwd=*)
        WORKSPACE_DIR="${1#*=}"
        shift
        ;;
      --profile)
        [[ $# -ge 2 ]] || die "--profile 需要参数"
        DEFAULT_PROFILE="$2"
        shift 2
        ;;
      --profile=*)
        DEFAULT_PROFILE="${1#*=}"
        shift
        ;;
      --state-root|--mycodex-root)
        [[ $# -ge 2 ]] || die "$1 需要参数"
        STATE_ROOT="$2"
        shift 2
        ;;
      --state-root=*|--mycodex-root=*)
        STATE_ROOT="${1#*=}"
        shift
        ;;
      --internal-state|--toolkit-state)
        USE_INTERNAL_STATE="1"
        shift
        ;;
      --import-existing-state)
        IMPORT_EXISTING_STATE="1"
        shift
        ;;
      --install-runtime)
        RUNTIME_MODE="install"
        shift
        ;;
      --skip-runtime)
        RUNTIME_MODE="skip"
        shift
        ;;
      --force)
        FORCE_WRITE="1"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "未知参数: $1"
        ;;
    esac
  done
}

main() {
  local guessed_project_root guessed_state_root project_root_relative workspace_relative
  local guessed_project_name chosen_profile
  local state_root_relative=""
  local -a profiles=()
  local profiles_count=0

  parse_args "$@"
  have_cmd python3 || die "需要 python3 生成 portable-init.env"
  ensure_keep_files

  guessed_project_root="$(default_project_root_guess)"
  if [[ -z "${PROJECT_ROOT}" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      PROJECT_ROOT="$(prompt_existing_dir_with_default "项目根目录" "${guessed_project_root}")"
    else
      PROJECT_ROOT="${guessed_project_root}"
    fi
  fi
  PROJECT_ROOT="$(resolve_abs_dir "${PROJECT_ROOT}")"

  guessed_project_name="$(basename "${PROJECT_ROOT}")"
  if [[ -z "${PROJECT_NAME}" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      PROJECT_NAME="$(prompt_with_default "项目名称" "${guessed_project_name}")"
    else
      PROJECT_NAME="${guessed_project_name}"
    fi
  fi
  [[ -n "${PROJECT_NAME}" ]] || die "项目名称不能为空"

  if [[ -z "${WORKSPACE_DIR}" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      WORKSPACE_DIR="$(prompt_existing_dir_with_default "默认工作目录" "${PROJECT_ROOT}")"
    else
      WORKSPACE_DIR="${PROJECT_ROOT}"
    fi
  fi
  WORKSPACE_DIR="$(resolve_abs_dir "${WORKSPACE_DIR}")"

  if [[ -z "${STATE_ROOT}" && "${USE_INTERNAL_STATE}" != "1" ]]; then
    guessed_state_root="$(default_state_root_guess || true)"
    if [[ -n "${guessed_state_root}" ]]; then
      STATE_ROOT="${guessed_state_root}"
    fi
  fi

  if [[ "${USE_INTERNAL_STATE}" == "1" ]]; then
    set_active_state_roots
    mkdir -p "${CONFIGS_ROOT}" "${SESSIONS_ROOT}"
  elif [[ -n "${STATE_ROOT}" ]]; then
    STATE_ROOT="$(ensure_abs_dir "${STATE_ROOT}")"
    set_active_state_roots
    mkdir -p "${CONFIGS_ROOT}" "${SESSIONS_ROOT}"
    if [[ "${IMPORT_EXISTING_STATE}" == "1" ]]; then
      copy_tree_if_target_empty "${INTERNAL_CONFIGS_ROOT}" "${CONFIGS_ROOT}" "configs"
      copy_tree_if_target_empty "${INTERNAL_SESSIONS_ROOT}" "${SESSIONS_ROOT}" "sessions"
    fi
  fi

  if [[ -n "${DEFAULT_PROFILE}" ]]; then
    profile_is_valid "${DEFAULT_PROFILE}" || die "默认 profile 不可用: ${DEFAULT_PROFILE}"
  else
    load_valid_profiles_into_array profiles
    profiles_count="${VALID_PROFILES_COUNT}"
    if [[ "${profiles_count}" -gt 0 ]]; then
      chosen_profile="$(default_profile_name)"
      if [[ "${profiles_count}" -gt 1 && -t 0 && -t 1 ]]; then
        DEFAULT_PROFILE="$(choose_profile_interactively "${chosen_profile}" "${profiles[@]}")"
      else
        DEFAULT_PROFILE="${chosen_profile}"
      fi
    fi
  fi

  if [[ -f "${INIT_CONFIG_PATH}" && "${FORCE_WRITE}" != "1" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      if ! prompt_yes_no "portable-init.env 已存在，是否覆盖" "n"; then
        printf '已取消。\n'
        exit 0
      fi
    else
      die "portable-init.env 已存在；如需覆盖请加 --force"
    fi
  fi

  project_root_relative="$(relative_to_toolkit_root "${PROJECT_ROOT}")"
  workspace_relative="$(relative_to_toolkit_root "${WORKSPACE_DIR}")"
  if [[ -n "${STATE_ROOT}" ]]; then
    state_root_relative="$(relative_to_toolkit_root "${STATE_ROOT}")"
  fi
  write_init_config "${project_root_relative}" "${workspace_relative}" "${state_root_relative}" "${USE_INTERNAL_STATE}"

  printf '\n初始化完成。\n'
  printf '配置文件：%s\n' "${INIT_CONFIG_PATH}"
  printf '项目名称：%s\n' "${PROJECT_NAME}"
  printf '项目根目录：%s\n' "${PROJECT_ROOT}"
  printf '项目根目录相对路径：%s\n' "${project_root_relative}"
  printf '默认工作目录：%s\n' "${WORKSPACE_DIR}"
  printf '默认工作目录相对路径：%s\n' "${workspace_relative}"
  if [[ -n "${DEFAULT_PROFILE}" ]]; then
    printf '默认 profile：%s\n' "${DEFAULT_PROFILE}"
  else
    printf '默认 profile：当前未发现有效 profile，请后续补齐 %s/<profile>/auth.json 和 config.toml\n' "${CONFIGS_ROOT}"
  fi
  if [[ -n "${STATE_ROOT}" ]]; then
    printf '外部状态根目录：%s\n' "${STATE_ROOT}"
    printf '外部状态根目录相对路径：%s\n' "${state_root_relative}"
    if [[ "${IMPORT_EXISTING_STATE}" == "1" ]]; then
      printf '状态迁移：已按需导入工具内已有 mycodex 内容\n'
    else
      printf '状态迁移：未导入工具内已有 mycodex，后续直接使用外部状态目录\n'
    fi
  else
    printf '状态目录：沿用工具内 mycodex/configs 和 mycodex/sessions\n'
  fi

  if [[ -z "${RUNTIME_MODE}" && -t 0 && -t 1 ]]; then
    if runtime_ready; then
      if prompt_yes_no "已检测到工具内 runtime。是否现在重新安装/更新 runtime" "n"; then
        RUNTIME_MODE="install"
      else
        RUNTIME_MODE="skip"
      fi
    else
      if prompt_yes_no "当前未检测到完整 runtime。是否现在执行 runtime install" "y"; then
        RUNTIME_MODE="install"
      else
        RUNTIME_MODE="skip"
      fi
    fi
  fi

  if [[ "${RUNTIME_MODE}" == "install" ]]; then
    printf '\n开始安装工具内 runtime...\n'
    "${SCRIPT_DIR}/codex-project-runtime" install
    printf '\nruntime 安装完成，继续输出初始化后的建议命令。\n'
  fi

  printf '\n下一步建议：\n'
  if [[ -n "${DEFAULT_PROFILE}" ]]; then
    printf '1. ./bin/codex-project where --profile %s\n' "${DEFAULT_PROFILE}"
    if ! runtime_ready; then
      printf '2. ./bin/codex-project runtime install\n'
      printf '3. ./bin/codex-project doctor --profile %s\n' "${DEFAULT_PROFILE}"
      printf '4. ./bin/codex-project start --profile %s\n' "${DEFAULT_PROFILE}"
    else
      printf '2. ./bin/codex-project doctor --profile %s\n' "${DEFAULT_PROFILE}"
      printf '3. ./bin/codex-project start --profile %s\n' "${DEFAULT_PROFILE}"
    fi
  else
    printf '1. 先补齐 %s/<profile>/auth.json 和 config.toml\n' "${CONFIGS_ROOT}"
    if ! runtime_ready; then
      printf '2. ./bin/codex-project runtime install\n'
      printf '3. ./bin/codex-project profiles\n'
    else
      printf '2. ./bin/codex-project profiles\n'
    fi
  fi
}

main "$@"
